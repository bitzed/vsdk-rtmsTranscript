# Zoom Video SDK App の SDK Key / SDK Secret
# Marketplace > Video SDK App > App Credentials から取得
ZM_RTMS_CLIENT=your_sdk_key_here
ZM_RTMS_SECRET=your_sdk_secret_here

# Webhook Secret Token
# Marketplace > App > Features > Event Subscriptions > Secret Token
ZOOM_SECRET_TOKEN=your_webhook_secret_token_here

# Webhook サーバーのポート (省略時: 3000)
PORT=3000
